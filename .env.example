# ─── Copia este archivo a ".env" y rellena tus valores ───

# PostgreSQL con pgvector (Supabase). Botón "Connect" → pestaña "Session pooler" → URI.
# Reemplaza [YOUR-PASSWORD] por la contraseña de tu base. Ejemplo:
# postgresql://postgres.xxxxx:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# ─────────────────── IA GRATIS (por defecto: Google Gemini) ───────────────────
# Crea tu API key gratis (sin tarjeta) en https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Generación: "gemini" (gratis) | "anthropic" (de pago)
GEN_PROVIDER=gemini
# Cadena de failover: cuando un modelo agota su cuota diaria del free tier (429), el
# sistema pasa automáticamente al siguiente. Multiplica la disponibilidad gratis sin tarjeta.
GEN_MODELS=gemma-4-31b-it,gemma-4-26b-a4b-it,gemini-2.5-flash-lite,gemini-flash-latest,gemini-2.5-flash,gemini-2.0-flash
# (Alternativa: un solo modelo con GEN_MODEL=gemini-2.5-flash-lite)

# Embeddings: "gemini" (gratis) | "openai" (de pago) | "local" (bge-m3, gratis pero pesado)
EMBED_PROVIDER=gemini
GEMINI_EMBED_MODEL=text-embedding-004
# EMBED_DIM se deduce solo del modelo (Gemini=768). Solo defínelo si usas un modelo no listado.
# EMBED_DIM=768

# Recuperación
TOP_K=6

# ─────────────────── Opciones de pago (déjalas vacías si usas Gemini) ───────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENAI_EMBED_MODEL=text-embedding-3-small
# LOCAL_EMBED_MODEL=BAAI/bge-m3
